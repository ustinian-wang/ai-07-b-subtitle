# B 站：部分字幕需登录 Cookie；推荐在前端「设置」页配置，或在此 fallback
BILIBILI_SESSDATA=

# 小红书：笔记解析 Cookie；推荐在「设置」页配置，或在此 fallback
XIAOHONGSHU_COOKIE=

# 对话助手（OpenAI 兼容接口）
# 推荐在前端「设置」页配置 openai_api_key / openai_base_url / openai_model；
# 本文件仅作 fallback（设置页优先，与 BILIBILI_SESSDATA 相同优先级）。
#
# OpenAI 官方示例：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# 讯飞星火 Lite 示例：
# OPENAI_API_KEY=<APIPassword 或 APIKey:APISecret>
# OPENAI_BASE_URL=https://spark-api-open.xf-yun.com/v1
# OPENAI_MODEL=lite
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Notion 同步（推荐在「设置」页配置，或在此 fallback）
NOTION_TOKEN=
NOTION_PARENT_ID=

BACKEND_PORT=8907
BACKEND_HOST=0.0.0.0
