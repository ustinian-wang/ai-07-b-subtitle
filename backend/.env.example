# B 站：部分字幕需登录 Cookie；推荐在前端「设置」页配置，或在此 fallback
BILIBILI_SESSDATA=

# 小红书：笔记解析 Cookie；推荐在「设置」页配置，或在此 fallback
XIAOHONGSHU_COOKIE=

# 对话助手（OpenAI 兼容接口）
# 推荐在前端「设置」页配置 openai_api_key / openai_base_url / openai_model；
# 本文件仅作 fallback（设置页优先，与 BILIBILI_SESSDATA 相同优先级）。
#
# 可从 monorepo 兄弟项目复制 backend/.env（勿提交真实密钥）：
#   projects/ai-03-writemd/backend/.env   — 星火 lite / OpenAI 兼容
#   projects/ai-06-req-agent/backend/.env — 星火或 Sub2API 网关
#   projects/ai-01-chat/.env              — 多 Provider（spark-lite / sub2api）
#
# OpenAI 官方示例：
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# 讯飞星火 Lite 示例（见 ai-03-writemd）：
# OPENAI_API_KEY=<APIPassword 或 APIKey:APISecret>
# OPENAI_BASE_URL=https://spark-api-open.xf-yun.com/v1
# OPENAI_MODEL=lite
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

BACKEND_PORT=8907
BACKEND_HOST=0.0.0.0
